<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodApp.ViewModels"
             x:Class="FoodApp.Views.HelpPage"
             x:DataType="vm:HelpViewModel"
             Style="{StaticResource PageStyle}"
             Title="{Binding Title}">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="12">
            <Label Text="{Binding HelpText}" LineBreakMode="WordWrap" FontSize="16" />
            <Label Style="{StaticResource CaptionStyle}"
                   Text="Accessibility: all controls have screen reader names. Text scales with system font size. Colors meet WCAG 2.1 AA contrast." />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
