<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodApp.Controls.NutritionLabel"
             x:Name="Root">
    <Border Style="{StaticResource CardBorderStyle}">
        <VerticalStackLayout Spacing="4" Padding="12">
            <Label Text="{Binding Source={x:Reference Root}, Path=Title}"
                   Style="{StaticResource SubTitleStyle}"
                   AutomationProperties.Name="Nutrition title" />
            <Label Text="{Binding Source={x:Reference Root}, Path=Calories, StringFormat='{0} kcal'}"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"
                   AutomationProperties.Name="Calorie value" />
            <Label Text="{Binding Source={x:Reference Root}, Path=Subtitle}"
                   Style="{StaticResource CaptionStyle}" />
        </VerticalStackLayout>
    </Border>
</ContentView>
