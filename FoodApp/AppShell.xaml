<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:FoodApp.Views"
       x:Class="FoodApp.AppShell"
       Title="NutriScan"
       FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent Title="Home"
                      ContentTemplate="{DataTemplate views:HomePage}"
                      Route="HomePage"
                      AutomationProperties.Name="Home tab" />
        <ShellContent Title="Scan"
                      ContentTemplate="{DataTemplate views:ScanPage}"
                      Route="ScanPage"
                      AutomationProperties.Name="Scan tab" />
        <ShellContent Title="Recipes"
                      ContentTemplate="{DataTemplate views:RecipesPage}"
                      Route="RecipesPage"
                      AutomationProperties.Name="Recipes tab" />
        <ShellContent Title="History"
                      ContentTemplate="{DataTemplate views:HistoryPage}"
                      Route="HistoryPage"
                      AutomationProperties.Name="History tab" />
        <ShellContent Title="Settings"
                      ContentTemplate="{DataTemplate views:SettingsPage}"
                      Route="SettingsPage"
                      AutomationProperties.Name="Settings tab" />
    </TabBar>

</Shell>
